# Chatos backend runtime config (no Docker)
# Edit this file after first installation:
#   sudo vim /etc/chatos/chatos-backend.env

HOST=127.0.0.1
PORT=__BACKEND_PORT__
NODE_ENV=production
LOG_LEVEL=info
LOG_MAX_FILES=7d
LOG_MAX_SIZE=10m
CORS_ORIGINS=*

# Optional fallback API key (recommended to configure keys in app model settings)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Database
DATABASE_TYPE=sqlite
NOTEPAD_DATA_DIR=/app/data/notepad

# Auth (replace with a strong random value)
AUTH_JWT_SECRET=__JWT_SECRET__
AUTH_ACCESS_TOKEN_TTL_SECONDS=43200

# Session summary worker defaults (optional)
SESSION_SUMMARY_JOB_ENABLED=true
SESSION_SUMMARY_JOB_INTERVAL_SECONDS=30
