USER_SERVICE_SMTP_HOST=smtp.qq.com
USER_SERVICE_SMTP_PORT=587
USER_SERVICE_SMTP_USERNAME=1798644410@qq.com
USER_SERVICE_SMTP_PASSWORD=
USER_SERVICE_EMAIL_FROM=1798644410@qq.com
USER_SERVICE_EMAIL_FROM_NAME=ChatOS
USER_SERVICE_REGISTER_CODE_TTL_SECONDS=600
USER_SERVICE_REGISTER_CODE_RESEND_SECONDS=60
USER_SERVICE_REGISTER_CODE_HOURLY_LIMIT=5
USER_SERVICE_REGISTER_CODE_MAX_ATTEMPTS=5
TASK_RUNNER_INTERNAL_API_SECRET=change_me_task_runner_internal_secret
