MEMORY_SERVER_HOST=0.0.0.0
MEMORY_SERVER_PORT=7080
MEMORY_SERVER_MONGODB_URI=mongodb://admin:admin@127.0.0.1:27018/admin
MEMORY_SERVER_MONGODB_DATABASE=memory_server
MEMORY_SERVER_WORKER_ENABLED=true
MEMORY_SERVER_AI_TIMEOUT_SECS=90
# Session-level concurrency (different sessions can run in parallel).
# Defaults to 3 when unset; final concurrency = min(this value, max_sessions_per_tick).
MEMORY_SERVER_SUMMARY_SESSION_CONCURRENCY=3
MEMORY_SERVER_ROLLUP_SESSION_CONCURRENCY=3
# Default AI config for summary jobs (used when per-user model config missing key)
# You can also set OPENAI_API_KEY / OPENAI_BASE_URL instead.
MEMORY_SERVER_OPENAI_API_KEY=
MEMORY_SERVER_OPENAI_BASE_URL=https://api.openai.com/v1
MEMORY_SERVER_OPENAI_MODEL=gpt-4o-mini
MEMORY_SERVER_OPENAI_TEMPERATURE=0.2
# false (recommended): if no usable key, job fails and records error.
# true: fallback to local non-AI summary text.
MEMORY_SERVER_ALLOW_LOCAL_SUMMARY_FALLBACK=false
# Optional service-to-service auth token. If set, every API request must carry X-Service-Token.
MEMORY_SERVER_SERVICE_TOKEN=
