# Chatos backend runtime config (no Docker)
# Edit this file after first installation:
#   sudo vim /etc/chatos/chatos-backend.env

HOST=127.0.0.1
BACKEND_PORT=__BACKEND_PORT__
NODE_ENV=production
LOG_LEVEL=info
LOG_MAX_FILES=7d
CORS_ORIGINS=*

# Optional fallback API key (recommended to configure keys in app model settings)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Database
DATABASE_TYPE=sqlite
NOTEPAD_DATA_DIR=/app/data/notepad

# Auth（兼容旧 token 签名）
# AUTH_JWT_SECRET 为当前主签名 secret；必要时可用 AUTH_COMPAT_SECRET 保留旧 token 兼容。
AUTH_JWT_SECRET=__JWT_SECRET__
AUTH_COMPAT_SECRET=
AUTH_ACCESS_TOKEN_TTL_SECONDS=43200

# Session summary worker defaults (optional)
SESSION_SUMMARY_JOB_ENABLED=true
SESSION_SUMMARY_JOB_INTERVAL_SECONDS=30

# Legacy auth backfill（迁移期可选）
LEGACY_AUTH_MONGODB_URI=mongodb://admin:admin@127.0.0.1:27018/admin
LEGACY_AUTH_MONGODB_DATABASE=legacy_auth

# Memory engine platform integration
MEMORY_ENGINE_BASE_URL=http://127.0.0.1:7081/api/memory-engine/v1
MEMORY_ENGINE_REQUEST_TIMEOUT_MS=5000
