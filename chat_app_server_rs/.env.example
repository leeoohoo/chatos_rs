# Optional fallback API key
# 说明：如果你在前端“模型配置”里为每个模型都填了 api_key，这里可以留空。
OPENAI_API_KEY=

# Optional
OPENAI_BASE_URL=https://api.openai.com/v1
HOST=0.0.0.0
# Container internal port (do not change unless nginx upstream is updated together)
PORT=3001
# Host published port for docker compose (change this to avoid local conflicts)
BACKEND_HOST_PORT=3001
# Backend image target:
# - runtime: slim production image (default)
# - runtime-full: includes python3/pip and common CLI tools
BACKEND_DOCKER_TARGET=runtime
# Extra apt packages for backend image (only applied when building runtime-full).
# Example: BACKEND_EXTRA_APT_PACKAGES=clang lldb nodejs npm
BACKEND_EXTRA_APT_PACKAGES=
NODE_ENV=production
LOG_LEVEL=info
CORS_ORIGINS=*

# Database (optional, sqlite is default)
DATABASE_TYPE=sqlite

# NOTE:
# Docker backend data/logs now use named volumes by default,
# so they are isolated from local dev data sources.

# Auth
AUTH_JWT_SECRET=change-me-in-production
AUTH_ACCESS_TOKEN_TTL_SECONDS=7200
