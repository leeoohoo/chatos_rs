# Shared local defaults for repository startup scripts.
# Copy this file to `.env` at repository root and adjust as needed.
# `chat_app_server_rs/.env` and `db_connection_hub/.env` can still override subsystem-only keys.

# Root startup ports
MAIN_BACKEND_PORT=3997
FRONTEND_PORT=8088

# Main backend runtime profile
NODE_ENV=development
HOST=0.0.0.0
LOG_LEVEL=info
CORS_ORIGINS=*

# OpenAI-compatible upstream
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Auth
# Production requires a real AUTH_JWT_SECRET.
AUTH_JWT_SECRET=dev-only-change-me-please
AUTH_COMPAT_SECRET=
AUTH_ACCESS_TOKEN_TTL_SECONDS=43200
CHATOS_USER_SERVICE_BASE_URL=http://127.0.0.1:39190
CHATOS_USER_SERVICE_REQUEST_TIMEOUT_MS=5000
CHATOS_PROJECT_SERVICE_BASE_URL=http://127.0.0.1:39210
CHATOS_DOCKER_PROJECT_SERVICE_BASE_URL=http://project-management-backend:39210
CHATOS_PROJECT_SERVICE_SYNC_SECRET=change_me_project_sync_secret
CHATOS_TASK_RUNNER_BASE_URL=http://127.0.0.1:39090
TASK_RUNNER_CHATOS_CALLBACK_SECRET=change_me_chatos_task_runner_secret
# Compose should use the in-network service name instead of localhost.
CHATOS_DOCKER_USER_SERVICE_BASE_URL=http://user-service-backend:39190

# Shared dev Mongo for local scripts
START_DEV_MONGO=auto
DEV_MONGO_MODE=local
DEV_MONGO_HOST=127.0.0.1
DEV_MONGO_PORT=27018
DEV_MONGO_CONTAINER_NAME=chatos-dev-mongo
LOCAL_MONGO_VERSION=7.0.37

# Chatos main backend database
DATABASE_TYPE=mongodb
MONGODB_HOST=127.0.0.1
MONGODB_PORT=27018
MONGODB_DB=chatos
MONGODB_USER=admin
MONGODB_PASSWORD=admin
MONGODB_AUTH_SOURCE=admin

# Memory engine integration
MEMORY_ENGINE_HOST=127.0.0.1
MEMORY_ENGINE_PORT=7081
MEMORY_ENGINE_FRONTEND_PORT=4178
MEMORY_ENGINE_BASE_URL=http://127.0.0.1:7081/api/memory-engine/v1
MEMORY_ENGINE_MONGODB_URI=mongodb://admin:admin@127.0.0.1:27018/admin
MEMORY_ENGINE_MONGODB_DATABASE=memory_engine
MEMORY_ENGINE_OPERATOR_TOKEN=chatos-memory-engine-dev-operator-token
MEMORY_ENGINE_USER_SERVICE_BASE_URL=http://127.0.0.1:39190
MEMORY_ENGINE_USER_SERVICE_REQUEST_TIMEOUT_MS=5000
VITE_USER_SERVICE_API_BASE=http://127.0.0.1:39190
MEMORY_ENGINE_REQUEST_TIMEOUT_MS=5000
MEMORY_ENGINE_ACTIVE_SUMMARY_TRIGGER_TIMEOUT_MS=5000
MEMORY_ENGINE_ACTIVE_SUMMARY_POLL_INTERVAL_MS=10000
MEMORY_ENGINE_ACTIVE_SUMMARY_POLL_TIMEOUT_MS=120000
MEMORY_ENGINE_START_DEV_MONGO=auto
MEMORY_ENGINE_DEV_MONGO_HOST=127.0.0.1
MEMORY_ENGINE_DEV_MONGO_PORT=27018
MEMORY_ENGINE_DEV_MONGO_CONTAINER_NAME=chatos-dev-mongo

# Root runtime control
RUNTIME_DIR=
STOP_BY_PORT=1
START_USER_SERVICE=1
START_MEMORY_ENGINE=1
START_CHATOS=1
START_TASK_RUNNER=1
START_PROJECT_MANAGEMENT=1
START_OFFICIAL_WEBSITE=0
STARTUP_HEALTHCHECK_TIMEOUT_SEC=45
MAIN_BACKEND_HEALTHCHECK_TIMEOUT_SEC=120
MAIN_FRONTEND_HEALTHCHECK_TIMEOUT_SEC=45

# official_website_service optional defaults
# dev: Rust backend + Vite dev server; prod: Rust backend serves frontend/dist only.
OFFICIAL_WEBSITE_MODE=dev
OFFICIAL_WEBSITE_HOST=127.0.0.1
OFFICIAL_WEBSITE_PORT=39250
OFFICIAL_WEBSITE_FRONTEND_PORT=39251
OFFICIAL_WEBSITE_STATIC_DIR=
OFFICIAL_WEBSITE_PUBLIC_BASE_URL=
OFFICIAL_WEBSITE_ENABLE_LIVE_STATUS=true
OFFICIAL_WEBSITE_STATUS_TIMEOUT_MS=800
OFFICIAL_WEBSITE_STATUS_SCHEME=http
OFFICIAL_WEBSITE_STATUS_HOST=127.0.0.1
OFFICIAL_WEBSITE_STATUS_CHATOS_URL=
OFFICIAL_WEBSITE_STATUS_MEMORY_ENGINE_URL=
OFFICIAL_WEBSITE_STATUS_USER_SERVICE_URL=
OFFICIAL_WEBSITE_STATUS_PROJECT_MANAGEMENT_URL=
OFFICIAL_WEBSITE_STATUS_SANDBOX_MANAGER_URL=
OFFICIAL_WEBSITE_STATUS_TASK_RUNNER_URL=
OFFICIAL_WEBSITE_STATUS_OFFICIAL_WEBSITE_URL=

# Optional WSL helper defaults for Windows -> WSL Rust development flow
WSL_DEV_DISTRO=
WSL_CARGO_TARGET_DIR=
WSL_RUNTIME_DIR=
WSL_USER_SERVICE_RUNTIME_DIR=
WSL_TASK_RUNNER_RUNTIME_DIR=
WSL_MEMORY_ENGINE_RUNTIME_DIR=

# db_connection_hub optional defaults
DB_HUB_BACKEND_HOST=0.0.0.0
DB_HUB_BACKEND_PORT=8099
DB_HUB_FRONTEND_HOST=0.0.0.0
DB_HUB_FRONTEND_PORT=5174
DB_HUB_BACKEND_RUST_LOG=info

# shared bootstrap admin for user_service, task_runner_service, and memory_engine sign-in
# memory_engine authenticates this user through user_service instead of creating its own user table
CHATOS_ADMIN_USERNAME=admin
CHATOS_ADMIN_PASSWORD=admin123456
CHATOS_ADMIN_DISPLAY_NAME=System Admin

# user_service optional defaults
USER_SERVICE_HOST=127.0.0.1
USER_SERVICE_PORT=39190
USER_SERVICE_FRONTEND_PORT=39191
USER_SERVICE_MONGODB_DATABASE=user_service
USER_SERVICE_DATABASE_URL=mongodb://admin:admin@127.0.0.1:27018/user_service?authSource=admin
USER_SERVICE_START_DEV_MONGO=auto
USER_SERVICE_DEV_MONGO_HOST=127.0.0.1
USER_SERVICE_DEV_MONGO_PORT=27018
USER_SERVICE_DEV_MONGO_CONTAINER_NAME=chatos-dev-mongo
USER_SERVICE_JWT_SECRET=change_me_user_service_secret
USER_SERVICE_JWT_ISSUER=user_service
USER_SERVICE_USER_AUDIENCE=user_service
USER_SERVICE_TASK_RUNNER_AUDIENCE=task_runner
USER_SERVICE_DOWNSTREAM_REQUEST_TIMEOUT_MS=5000
USER_SERVICE_API_PROXY_TARGET=http://127.0.0.1:39190
USER_SERVICE_USER_ACCESS_TTL_SECONDS=43200
USER_SERVICE_TASK_RUNNER_ACCESS_TTL_SECONDS=3600
USER_SERVICE_SUPER_ADMIN_USERNAME=admin
USER_SERVICE_SUPER_ADMIN_PASSWORD=admin123456
USER_SERVICE_SUPER_ADMIN_DISPLAY_NAME=System Admin
TASK_RUNNER_BASE_URL=http://127.0.0.1:39090

# optional Harness public-register provisioning for newly created Chatos users
HARNESS_PROVISIONING_ENABLED=false
HARNESS_BASE_URL=http://8.155.171.124:3000
HARNESS_SYNTHETIC_EMAIL_DOMAIN=chatos.local
HARNESS_SPACE_PREFIX=u-
HARNESS_PROJECT_PAT_PREFIX=chatos-project
HARNESS_REQUEST_TIMEOUT_MS=5000
USER_SERVICE_INTERNAL_API_SECRET=change_me_user_service_internal_secret

# task_runner consuming user_service task token
TASK_RUNNER_BACKEND_PORT=39090
TASK_RUNNER_FRONTEND_PORT=39091
TASK_RUNNER_STORE_MODE=mongo
TASK_RUNNER_DATABASE_URL=mongodb://admin:admin@127.0.0.1:27018/task_runner_service?authSource=admin
TASK_RUNNER_START_DEV_MONGO=auto
TASK_RUNNER_DEV_MONGO_HOST=127.0.0.1
TASK_RUNNER_DEV_MONGO_PORT=27018
TASK_RUNNER_DEV_MONGO_CONTAINER_NAME=chatos-dev-mongo
TASK_RUNNER_MEMORY_ENGINE_BASE_URL=http://127.0.0.1:7081/api/memory-engine/v1
TASK_RUNNER_MEMORY_ENGINE_SOURCE_ID=task
TASK_RUNNER_MEMORY_ENGINE_OPERATOR_TOKEN=chatos-memory-engine-dev-operator-token
TASK_RUNNER_USER_SERVICE_BASE_URL=http://127.0.0.1:39190
TASK_RUNNER_USER_SERVICE_REQUEST_TIMEOUT_MS=5000
TASK_RUNNER_PROJECT_SERVICE_BASE_URL=http://127.0.0.1:39210
TASK_RUNNER_PROJECT_SERVICE_SYNC_SECRET=change_me_project_sync_secret
TASK_RUNNER_PROJECT_SERVICE_REQUEST_TIMEOUT_MS=5000
TASK_RUNNER_ROLE=all
TASK_RUNNER_WORKER_ID=
TASK_RUNNER_WORKER_POLL_MS=1000
TASK_RUNNER_WORKER_CLAIM_TTL_MS=120000
TASK_RUNNER_WORKER_CONCURRENCY=4

# sandbox_manager_service auth and Task Runner system access
# Keep false for local unauthenticated sandbox admin console compatibility.
# Set true in shared/dev/prod environments once callers send credentials.
SANDBOX_MANAGER_REQUIRE_AUTH=false
SANDBOX_MANAGER_OPERATOR_TOKEN=chatos-sandbox-manager-dev-operator-token
SANDBOX_MANAGER_AGENT_TOKEN_SECRET=change_me_sandbox_agent_token_secret
SANDBOX_MANAGER_USER_SERVICE_BASE_URL=http://127.0.0.1:39190
SANDBOX_MANAGER_USER_SERVICE_REQUEST_TIMEOUT_MS=5000
SANDBOX_MANAGER_SYSTEM_CLIENT_ID=task_runner
SANDBOX_MANAGER_SYSTEM_CLIENT_KEY=chatos-task-runner-sandbox-dev-key
SANDBOX_MANAGER_SYSTEM_CLIENT_SCOPES=sandbox.lease.create,sandbox.lease.read,sandbox.lease.release,sandbox.mcp.tools,sandbox.mcp.call,sandbox.pool.read,sandbox.images.read
SANDBOX_MANAGER_SYSTEM_CLIENT_ALLOWED_TENANT_IDS=*
SANDBOX_MANAGER_SYSTEM_CLIENT_ALLOWED_PROJECT_IDS=*
SANDBOX_MANAGER_SYSTEM_CLIENT_ALLOWED_TOOLS=*
SANDBOX_MANAGER_SYSTEM_CLIENT_MAX_LEASE_TTL_SECONDS=7200
TASK_RUNNER_SANDBOX_MANAGER_BASE_URL=http://127.0.0.1:8095
TASK_RUNNER_SANDBOX_MANAGER_CLIENT_ID=task_runner
TASK_RUNNER_SANDBOX_MANAGER_CLIENT_KEY=chatos-task-runner-sandbox-dev-key

# project_management_service defaults
PROJECT_SERVICE_HOST=127.0.0.1
PROJECT_SERVICE_PORT=39210
PROJECT_SERVICE_FRONTEND_PORT=39211
PROJECT_SERVICE_MONGODB_DATABASE=project_management_service
PROJECT_SERVICE_DATABASE_URL=mongodb://admin:admin@127.0.0.1:27018/project_management_service?authSource=admin
PROJECT_SERVICE_USER_SERVICE_BASE_URL=http://127.0.0.1:39190
PROJECT_SERVICE_DOCKER_USER_SERVICE_BASE_URL=http://user-service-backend:39190
PROJECT_SERVICE_USER_SERVICE_REQUEST_TIMEOUT_MS=5000
PROJECT_SERVICE_TASK_RUNNER_BASE_URL=http://127.0.0.1:39090
PROJECT_SERVICE_DOCKER_TASK_RUNNER_BASE_URL=http://task-runner-backend:39090
PROJECT_SERVICE_TASK_RUNNER_REQUEST_TIMEOUT_MS=10000
PROJECT_SERVICE_SYNC_SECRET=change_me_project_sync_secret
PROJECT_SERVICE_USER_SERVICE_INTERNAL_SECRET=change_me_user_service_internal_secret
PROJECT_SERVICE_CLOUD_PROJECT_IMPORT_ENABLED=true
PROJECT_SERVICE_CLOUD_PROJECT_MAX_ZIP_BYTES=104857600
PROJECT_SERVICE_CLOUD_PROJECT_MAX_UNPACKED_BYTES=524288000
PROJECT_SERVICE_CLOUD_PROJECT_MAX_FILES=20000
PROJECT_SERVICE_CLOUD_PROJECT_GIT_TIMEOUT_MS=300000
