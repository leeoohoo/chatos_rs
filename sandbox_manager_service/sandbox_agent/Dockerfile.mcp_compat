ARG CHATOS_SANDBOX_BASE_IMAGE=chatos-sandbox-agent:toolchain-base
FROM ${CHATOS_SANDBOX_BASE_IMAGE}

ENV CHATOS_AGENT_HOST=0.0.0.0
ENV CHATOS_AGENT_PORT=49888
ENV CHATOS_WORKSPACE=/workspace

COPY compat_agent.py /opt/chatos-sandbox-agent/compat_agent.py

WORKDIR /workspace
EXPOSE 49888

ENTRYPOINT ["python3", "/opt/chatos-sandbox-agent/compat_agent.py"]
