# Optional fallback API key
# 说明：如果你在前端“模型配置”里为每个模型都填了 api_key，这里可以留空。
OPENAI_API_KEY=

# Optional
OPENAI_BASE_URL=https://api.openai.com/v1
HOST=0.0.0.0
# Backend listen port (use dedicated BACKEND_PORT to avoid conflicts with global PORT env)
BACKEND_PORT=3997
# Backend image target:
# - runtime: slim production image (default)
# - runtime-full: includes python3/pip and common CLI tools
BACKEND_DOCKER_TARGET=runtime
# Extra apt packages for backend image (only applied when building runtime-full).
# Example: BACKEND_EXTRA_APT_PACKAGES=clang lldb nodejs npm
BACKEND_EXTRA_APT_PACKAGES=
NODE_ENV=production
LOG_LEVEL=info
CORS_ORIGINS=*

# Database (Mongo is default for local unified user/task setup)
DATABASE_TYPE=mongodb
MONGODB_HOST=127.0.0.1
MONGODB_PORT=27018
MONGODB_DB=chatos
MONGODB_USER=admin
MONGODB_PASSWORD=admin
MONGODB_AUTH_SOURCE=admin

# NOTE:
# Docker backend data/logs now use named volumes by default,
# so they are isolated from local dev data sources.

# Auth（兼容旧 token 签名）
# AUTH_JWT_SECRET 是当前主签名 secret；若未显式设置，会回退读取 AUTH_COMPAT_SECRET。
AUTH_JWT_SECRET=change-me-in-production
AUTH_COMPAT_SECRET=
AUTH_ACCESS_TOKEN_TTL_SECONDS=7200
CHATOS_USER_SERVICE_BASE_URL=http://127.0.0.1:39190
CHATOS_USER_SERVICE_REQUEST_TIMEOUT_MS=5000
CHATOS_USER_SERVICE_JWT_SECRET=change_me_user_service_secret
CHATOS_USER_SERVICE_JWT_ISSUER=user_service
CHATOS_USER_SERVICE_USER_AUDIENCE=user_service
CHATOS_TASK_RUNNER_BASE_URL=http://127.0.0.1:39090
TASK_RUNNER_CHATOS_CALLBACK_SECRET=change_me_chatos_task_runner_secret

# Legacy auth backfill（迁移期可选）
LEGACY_AUTH_MONGODB_URI=mongodb://admin:admin@127.0.0.1:27018/admin
LEGACY_AUTH_MONGODB_DATABASE=legacy_auth

# Memory engine platform integration
MEMORY_ENGINE_HOST=127.0.0.1
MEMORY_ENGINE_PORT=7081
MEMORY_ENGINE_BASE_URL=http://127.0.0.1:7081/api/memory-engine/v1
MEMORY_ENGINE_REQUEST_TIMEOUT_MS=5000
