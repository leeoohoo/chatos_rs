# Root `.env` is now reserved for host-side Local Connector Client settings.
# Cloud/server deployment settings live in `docker/.env.example`.

LOCAL_CONNECTOR_SERVICE_PORT=39230
LOCAL_CONNECTOR_CORE_API_PORT=39232
LOCAL_CONNECTOR_CLIENT_FRONTEND_PORT=39233

LOCAL_CONNECTOR_CLOUD_BASE_URL=http://127.0.0.1:39230
LOCAL_CONNECTOR_USER_SERVICE_BASE_URL=http://127.0.0.1:39190

LOCAL_CONNECTOR_ACCESS_TOKEN=
LOCAL_CONNECTOR_DEVICE_NAME=
LOCAL_CONNECTOR_PUBLIC_KEY=
LOCAL_CONNECTOR_WORKSPACE_PATH=
LOCAL_CONNECTOR_WORKSPACE_ALIAS=
LOCAL_CONNECTOR_STATE_PATH=

LOCAL_CONNECTOR_CLIENT_CARGO_TARGET_DIR=local_connector_client/target

# Optional shared user-service endpoint for the host-side client.
USER_SERVICE_PORT=39190
CHATOS_USER_SERVICE_BASE_URL=http://127.0.0.1:39190
