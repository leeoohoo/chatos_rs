# Chatos backend runtime config (no Docker)
# Edit this file after first installation:
#   sudo vim /etc/chatos/chatos-backend.env

HOST=127.0.0.1
PORT=__BACKEND_PORT__
NODE_ENV=production
LOG_LEVEL=info
LOG_MAX_FILES=7d
LOG_MAX_SIZE=10m
CORS_ORIGINS=*

# Optional fallback API key (recommended to configure keys in app model settings)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Database
DATABASE_TYPE=sqlite
NOTEPAD_DATA_DIR=/app/data/notepad

# Auth（统一委托给 memory_server）
# AUTH_* 字段仅用于兼容返回结构中的 expires_in 展示，不再承担本地用户鉴权。
AUTH_JWT_SECRET=__JWT_SECRET__
AUTH_ACCESS_TOKEN_TTL_SECONDS=43200

# Session summary worker defaults (optional)
SESSION_SUMMARY_JOB_ENABLED=true
SESSION_SUMMARY_JOB_INTERVAL_SECONDS=30

# Memory server integration.
# MEMORY_SERVER_REMOTE_ONLY=true means session/message/summaries are served by memory_server,
# and local summary/archive workers are skipped.
# MEMORY_SERVER_CONTEXT_ENABLED only affects non-remote-only mode.
MEMORY_SERVER_CONTEXT_ENABLED=false
MEMORY_SERVER_REMOTE_ONLY=true
MEMORY_SERVER_BASE_URL=http://127.0.0.1:7080/api/memory/v1
MEMORY_SERVER_SERVICE_TOKEN=
MEMORY_SERVER_CONTEXT_TIMEOUT_MS=3000
MEMORY_SERVER_REQUEST_TIMEOUT_MS=5000
