# Set true only for emergency use.
OPENAPI_GATE_WAIVER_ENABLED=false

# Unique identifier (ticket/incident/change-id).
OPENAPI_GATE_WAIVER_ID=INC-2026-0001

# Who approved this waiver.
OPENAPI_GATE_WAIVER_APPROVER=oncall-owner

# Why this waiver is needed.
OPENAPI_GATE_WAIVER_REASON=Emergency API hotfix, OpenAPI contract update follows in next PR.

# Absolute expiration in ISO-8601 UTC format.
# Example: 2026-04-11T08:00:00Z
OPENAPI_GATE_WAIVER_EXPIRES_AT=2026-04-11T08:00:00Z
