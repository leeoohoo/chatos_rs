# syntax=docker/dockerfile:1.7

FROM rust:1.93-bookworm AS builder

WORKDIR /workspace/agent_orchestrator

RUN apt-get update \
    && apt-get install -y --no-install-recommends pkg-config libssl-dev clang \
    && rm -rf /var/lib/apt/lists/*

COPY agent_orchestrator/Cargo.toml agent_orchestrator/Cargo.lock ./
COPY agent_orchestrator/src ./src
COPY agent_orchestrator/config ./config

RUN cargo build --release

FROM debian:bookworm-slim AS runtime-base

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates libsqlite3-0 libssl3 \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /workspace/agent_orchestrator/target/release/agent_orchestrator /app/agent_orchestrator
COPY agent_orchestrator/config /app/config

RUN mkdir -p /app/data /app/logs

ENV NODE_ENV=production \
    HOST=0.0.0.0 \
    PORT=3001 \
    OPENAI_BASE_URL=https://api.openai.com/v1

EXPOSE 3001
CMD ["/app/agent_orchestrator"]

FROM runtime-base AS runtime

FROM runtime-base AS runtime-full

ARG BACKEND_EXTRA_APT_PACKAGES=""

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
      bash \
      build-essential \
      cmake \
      curl \
      git \
      iproute2 \
      iputils-ping \
      jq \
      less \
      nano \
      net-tools \
      pkg-config \
      procps \
      python3 \
      python3-dev \
      python3-pip \
      python3-venv \
      openjdk-17-jdk \
      maven \
      rsync \
      unzip \
      vim \
      wget \
      zip \
    && if [ -n "$BACKEND_EXTRA_APT_PACKAGES" ]; then apt-get install -y --no-install-recommends $BACKEND_EXTRA_APT_PACKAGES; fi \
    && ln -sf /usr/bin/python3 /usr/local/bin/python \
    && ln -sf /usr/bin/pip3 /usr/local/bin/pip \
    && rm -rf /var/lib/apt/lists/*
