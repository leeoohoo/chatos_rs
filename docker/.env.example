# Copy this file to docker/.env for deployment-specific overrides.

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

MONGODB_USER=admin
MONGODB_PASSWORD=admin
MONGODB_HOST_PORT=27018

CHATOS_ADMIN_USERNAME=admin
CHATOS_ADMIN_PASSWORD=admin123456
CHATOS_ADMIN_DISPLAY_NAME=System Admin

AUTH_JWT_SECRET=dev-only-change-me-please
USER_SERVICE_JWT_SECRET=change_me_user_service_secret
USER_SERVICE_INTERNAL_API_SECRET=change_me_user_service_internal_secret
TASK_RUNNER_INTERNAL_API_SECRET=change_me_task_runner_internal_secret
TASK_RUNNER_CHATOS_CALLBACK_SECRET=change_me_chatos_task_runner_secret
CHATOS_PROJECT_SERVICE_SYNC_SECRET=change_me_project_sync_secret
CHATOS_LOCAL_CONNECTOR_INTERNAL_API_SECRET=chatos-local-connector-dev-secret

CHATOS_DOCKER_NETWORK=chatos-cloud
CHATOS_DOCKER_MODE=prebuilt
CHATOS_IMAGE_NAMESPACE=ghcr.io/leeoohoo
CHATOS_IMAGE_TAG=latest
SANDBOX_MANAGER_DOCKER_IMAGE=ghcr.io/leeoohoo/chatos-rs-sandbox-agent:latest

CHATOS_ENV=local
CHATOS_SERVICE_RUNTIME_ENABLED=true
CHATOS_SERVICE_DISCOVERY_MODE=consul,static
CHATOS_CONSUL_HTTP_ADDR=http://consul:8500
CHATOS_SERVICE_RUNTIME_REQUEST_TIMEOUT_MS=3000
CONSUL_IMAGE=hashicorp/consul:1.21
CONSUL_HTTP_PORT=8500

HARNESS_IMAGE=harness/harness:latest
HARNESS_PUBLIC_BASE_URL=http://localhost:3000
HARNESS_ADMIN_EMAIL=admin@chatos.local
HARNESS_ADMIN_PASSWORD=admin123456
HARNESS_SSH_HOST=localhost
HARNESS_GITSPACE_ENABLE=true
HARNESS_PROVISIONING_ENABLED=true
HARNESS_BASE_URL=http://harness:3000
HARNESS_SYNTHETIC_EMAIL_DOMAIN=chatos.local
HARNESS_SPACE_PREFIX=u-
HARNESS_PROJECT_PAT_PREFIX=chatos-project

FRONTEND_PORT=8088
MAIN_BACKEND_PORT=3997
HARNESS_PORT=3000
HARNESS_SSH_PORT=3022
USER_SERVICE_PORT=39190
USER_SERVICE_FRONTEND_PORT=39191
MEMORY_ENGINE_PORT=7081
MEMORY_ENGINE_FRONTEND_PORT=4178
TASK_RUNNER_BACKEND_PORT=39090
TASK_RUNNER_FRONTEND_PORT=39091
PROJECT_SERVICE_PORT=39210
PROJECT_SERVICE_FRONTEND_PORT=39211
LOCAL_CONNECTOR_SERVICE_PORT=39230
SANDBOX_MANAGER_PORT=8095
SANDBOX_MANAGER_FRONTEND_PORT=8096
DB_HUB_BACKEND_PORT=8099
DB_HUB_FRONTEND_PORT=5174
OFFICIAL_WEBSITE_PORT=39250
OFFICIAL_WEBSITE_FRONTEND_PORT=39251
